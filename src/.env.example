# ============================================================
# Dev Tracer Bot — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Bot Token ---
# Create a bot via @BotFather on Telegram → /newbot
BOT_TOKEN=your_bot_token_here

# --- Helius API (required) ---
# Free tier: https://helius.dev
# Multiple keys supported (comma-separated) — rotates on rate limit
# More keys = faster tracing (each key = 10 RPC/s)
HELIUS_API_KEYS=key1,key2,key3

# --- Alert Chat ID ---
# Where the bot sends trace results
# To get chat ID: send /start to @userinfobot, or check Telegram Web URL
PUMP_ALERT_CHAT_ID=-1001234567890

# --- Dev Alert (optional) ---
# Separate chat for dev trace results (defaults to PUMP_ALERT_CHAT_ID)
# DEV_ALERT_CHAT_ID=-1001234567890

# --- Separate Bot Token (optional) ---
# If you want dev alerts sent by a different bot
# DEV_ALERT_BOT_TOKEN=your_other_bot_token

# --- Moralis API (optional) ---
# Token discovery — https://moralis.io
# Multiple keys supported (comma-separated)
# MORALIS_API_KEYS=key1,key2

# --- Free RPC Providers (optional, supplement Helius) ---
# SHYFT_API_KEY=your_shyft_key
# ALCHEMY_API_KEY=your_alchemy_key
# ANKR_API_KEY=your_ankr_key
# CHAINSTACK_API_KEY=your_chainstack_key
# BIRDEYE_API_KEY=your_birdeye_key

# --- Admin ---
# Comma-separated Telegram user IDs for admin access
# Get your ID: send /start to @userinfobot
ADMIN_IDS=

# --- Trace Chain Settings ---
# Loop detection: stop after N visits to same wallet (default: 20)
# TRACE_LOOP_THRESHOLD=20
# Batch size for large trace jobs (default: 10)
# TRACE_BATCH_SIZE=10
# Threshold to enable batching (default: 30 wallets)
# TRACE_BATCH_THRESHOLD=30

# --- Logging ---
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
